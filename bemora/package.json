{
  "name": "bemora",
  "version": "1.0.0-alpha.3",
  "description": "Unified API library for apps and AI agents — payments (Stripe, PayPal), email (SendGrid, SES, Resend), SMS (Twilio), auth (JWT, Clerk, Auth0), storage (S3, R2, GCS), vector DBs, AI providers (OpenAI, Anthropic, Gemini, Groq, & more), Cloudflare, and 100+ other APIs — all with circuit breakers, retries, PII redaction, and multi-tenant support (beta/alpha)",
  "main": "src/index.js",
  "types": "src/types/index.d.ts",
  "type": "module",
  "bin": {
    "bemora": "./src/cli.js",
    "bemora-mcp": "./src/mcp-server/index.js"
  },
  "scripts": {
    "demo": "node examples/zero-key-demo.js",
    "start": "node src/index.js",
    "mcp": "node src/mcp-server/index.js",
    "cli": "node src/cli.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:integration": "vitest run --config vitest.config.integration.js",
    "lint": "echo \"Linting...\""
  },
  "exports": {
    ".": {
      "import": "./src/index.js",
      "default": "./src/index.js"
    },
    "./edge": "./src/edge.js",
    "./redis": "./src/core/cache-redis.js",
    "./paginate": "./src/core/paginate.js",
    "./gql": "./src/core/gql.js",
    "./upload": "./src/core/upload.js",
    "./batch": "./src/core/batch.js",
    "./webhooks": "./src/core/webhooks.js",
    "./audit": "./src/core/audit.js",
    "./errors": "./src/core/errors.js"
  },
