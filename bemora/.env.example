# ================================================================
# bemora — Full API Keys Configuration
# Copy this file to .env and fill in your free keys
# ================================================================

# ── Core ─────────────────────────────────────────────────────────
# Weather — FREE: https://openweathermap.org/api
BEMORA_WEATHER_KEY=

# Currency — FREE: https://www.exchangerate-api.com
BEMORA_CURRENCY_KEY=

# News — FREE: https://newsapi.org/register
BEMORA_NEWS_KEY=

# Images (Unsplash) — FREE: https://unsplash.com/developers
BEMORA_UNSPLASH_KEY=

# Images (Pexels) — FREE: https://www.pexels.com/api
BEMORA_PEXELS_KEY=

# Football — FREE: https://dashboard.api-football.com/register
BEMORA_FOOTBALL_KEY=

# Gold/Silver — FREE: https://www.goldapi.io
BEMORA_GOLD_KEY=

# ── New Providers ─────────────────────────────────────────────────
# NASA (Space, APOD, Mars) — FREE: https://api.nasa.gov
BEMORA_NASA_KEY=

# Movies/TV (TMDB) — FREE: https://www.themoviedb.org/settings/api
BEMORA_MOVIES_KEY=

# Stocks (Alpha Vantage) — FREE: https://www.alphavantage.co/support/#api-key
BEMORA_STOCKS_KEY=

# ── AI Providers ─────────────────────────────────────────────────
# Groq (Llama 3, Mixtral — FREE tier!) — https://console.groq.com
BEMORA_GROQ_KEY=

# OpenAI (GPT-4o, DALL-E 3) — https://platform.openai.com
BEMORA_OPENAI_KEY=

# Flights (AviationStack) — FREE: https://aviationstack.com/product
BEMORA_FLIGHTS_KEY=

# ── No key needed (built-in free) ────────────────────────────────
# Location (Nominatim/OpenStreetMap) — no key
# IP Intelligence (ip-api.com) — no key
# Countries (restcountries.com) — no key
# Translation (MyMemory) — no key (1000 words/day free)
# Crypto (CoinGecko) — no key
# Food (TheMealDB) — no key
# Music (MusicBrainz + iTunes) — no key
# Space: ISS position — no key
# Search (DuckDuckGo) — no key
# Social (GitHub, Hacker News) — no key
# Utils: QR, timezone, holidays, quotes, dictionary, trivia, colors — no key
# Prayer times (Aladhan) — no key
# Anime (Jikan/MAL) — no key
# Fun: jokes, cat facts, dog images, random users, affirmations — no key
# Art: Art Institute Chicago + Metropolitan Museum — no key
# Dev tools: npm info, GitHub repos/releases, DNS, email validation — no key
# Podcasts: iTunes + RSS feed parser — no key
# Health: FDA drugs, nutrition, exercises, BMI calculator — no key

# ── Options ──────────────────────────────────────────────────────
BEMORA_LOG_LEVEL=info
